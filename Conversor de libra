Console.OutputEncoding = System.Text.Encoding.UTF8;
//declaracao de variaveis locais
float moeda, converorReal, resultado;
int escolha;
Console.WriteLine("Conversor de Moedas00");
Console.Write("Digite o Valor em Reais que voce quer converter: ");
float.TryParse(Console.ReadLine()!, out moeda);
Console.WriteLine("\nDigite 1 para converter para libra\n");
int.TryParse(Console.ReadLine(), out escolha);
switch (escolha)
{
    case 1:
        Console.Write("Digite o valor da libra turismo: ");
        float.TryParse(Console.ReadLine()!.Replace(". ", ","), out converorReal);
        resultado = moeda / converorReal;
        Console.WriteLine($"R${moeda} / £{converorReal} =  £{resultado}");
        break;
    default:
        Console.WriteLine("Digite um valor válido");
        break;
}
